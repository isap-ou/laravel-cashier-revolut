{
    "name": "isapp/laravel-cashier-revolut",
    "description": "Revolut payment gateway driver for Laravel Cashier — subscriptions, charges, invoices via Revolut Merchant API",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cashier", "revolut", "billing", "subscriptions", "payments", "merchant-api"],
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "isapp/laravel-cashier-support": "^1.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0",
        "moneyphp/money": "^4.5",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "IsApp\\CashierRevolut\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IsApp\\CashierRevolut\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IsApp\\CashierRevolut\\CashierRevolutServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
