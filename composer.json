{
    "name": "isapp/laravel-cashier-revolut",
    "description": "Revolut payment gateway driver for Laravel Cashier — charges, subscriptions, checkout and webhooks via the Revolut Merchant API",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cashier", "revolut", "billing", "subscriptions", "payments", "merchant-api"],
    "homepage": "https://github.com/isap-ou/laravel-cashier-revolut",
    "authors": [
        {
            "name": "ISAPP",
            "homepage": "https://isapp.be"
        }
    ],
    "support": {
        "issues": "https://github.com/isap-ou/laravel-cashier-revolut/issues",
        "source": "https://github.com/isap-ou/laravel-cashier-revolut"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "isap-ou/laravel-enum-helpers": "^1.5",
        "isapp/laravel-cashier-support": "^1.3",
        "moneyphp/money": "^4.9",
        "nesbot/carbon": "^3.0",
        "psr/log": "^3.0",
        "spatie/laravel-data": "^4.23",
        "symfony/http-foundation": "^7.0|^8.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../laravel-cashier-support",
            "options": {
                "symlink": true,
                "versions": {
                    "isapp/laravel-cashier-support": "1.3.0"
                }
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Isapp\\CashierRevolut\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Isapp\\CashierRevolut\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Isapp\\CashierRevolut\\CashierRevolutServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "ci": [
            "@test",
            "@analyse",
            "@lint"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
